{
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline/statusline.sh\""
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/biome-format.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/prisma-generate.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/status-reminder.sh\""
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(pnpm nx test*)",
      "Bash(pnpm nx lint*)",
      "Bash(pnpm nx build*)",
      "Bash(pnpm nx serve*)",
      "Bash(pnpm nx run*)",
      "Bash(pnpm nx affected*)",
      "Bash(pnpm nx graph*)",
      "Bash(pnpm install*)",
      "Bash(pnpm check*)",
      "Bash(pnpm format*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git switch *)",
      "Bash(git checkout -b *)",
      "Bash(git show *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo view*)",
      "Bash(gh release *)",
      "Bash(npx biome *)",
      "Bash(curl localhost*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(rm -rf*)",
      "Bash(git reset --hard*)",
      "Bash(git stash drop*)",
      "Bash(docker system prune*)",
      "Write(.env)",
      "Write(.env.staging)",
      "Write(.env.production)",
      "Write(.env.local)",
      "Edit(.env)",
      "Edit(.env.staging)",
      "Edit(.env.production)",
      "Edit(.env.local)"
    ]
  }
}
