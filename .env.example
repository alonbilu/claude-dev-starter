# =============================================================================
# Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Or use the interactive wizard:
#   bash scripts/setup-env.sh --env dev
#
# NEVER commit .env files — they contain secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/myapp_dev
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5443/myapp_test

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=3333
CLIENT_PORT=4200
CLIENT_URL=http://localhost:4200

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-a-real-secret
BETTER_AUTH_URL=http://localhost:3333

# -----------------------------------------------------------------------------
# Optional: Email (Resend)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Optional: Payments (Stripe)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Optional: Storage (S3-compatible)
# -----------------------------------------------------------------------------
# S3_ENDPOINT=https://your-region.digitaloceanspaces.com
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_REGION=your-region

# -----------------------------------------------------------------------------
# Optional: AI / LLM
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Optional: Redis (for BullMQ queues)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
