# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development           # development | staging | production
APP_NAME=your-app-name         # used in logs, docker container names, scripts

# ─── API ────────────────────────────────────────────────────────────────────
API_PORT=3333                  # configured by /setup-project
CLIENT_URL=http://localhost:4200  # CORS allowed origin (set to public domain in prod)

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5442/appdb
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5443/appdb_test

# ─── Auth ───────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=            # REQUIRED — generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:4200   # public client URL for auth redirects

# ─── Redis (opt-in: queue integration) ─────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Payments (opt-in: payments integration) ────────────────────────────────
# STRIPE_SECRET_KEY=           # sk_test_... (dev) / sk_live_... (prod)
# STRIPE_WEBHOOK_SECRET=       # whsec_...
# STRIPE_PRICE_ID_PRO=         # price_...

# ─── Email (opt-in: email integration) ──────────────────────────────────────
# RESEND_API_KEY=              # re_...
# EMAIL_FROM=noreply@yourdomain.com

# ─── Storage (opt-in: storage integration) ──────────────────────────────────
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_ENDPOINT=https://YOUR_REGION.digitaloceanspaces.com
# DO_SPACES_BUCKET=your-bucket-name
# DO_SPACES_CDN_URL=           # optional CDN endpoint

# ─── LLM (opt-in: llm integration) ─────────────────────────────────────────
# OPENAI_API_KEY=              # sk-...
# ANTHROPIC_API_KEY=           # sk-ant-...
# DEFAULT_LLM_PROVIDER=openai  # openai | anthropic

# ─── RAG / Vector Search (opt-in: rag integration) ──────────────────────────
# Requires pgvector/pgvector:pg16 Docker image (swap in docker-compose.yml)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536
