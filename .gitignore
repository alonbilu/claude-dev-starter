# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/

# Environment files — NEVER commit these
.env
.env.local
.env.staging
.env.production
.env.*.local

# Nx cache
.nx/cache
.nx/workspace-data

# Generated files
**/generated/
*.generated.ts
*.generated.js

# Prisma
prisma/migrations/*.sql
# Note: Keep prisma/migrations/ directory and migration files committed

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo
*.code-workspace

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
HANDOVER.md

# Claude context trim backups (auto-generated, not needed in git)
.claude/context-trim-backup-*/

# Local state files (machine-specific, not shared)
.claude/.last-update-check
